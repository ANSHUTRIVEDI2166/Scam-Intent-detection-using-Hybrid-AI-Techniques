# API Configuration
API_KEY=your-secret-api-key-here
HOST=0.0.0.0
PORT=8000

# NVIDIA NIMs API Key (required for LLM-based detection and responses)
NVIDIA_API_KEY=your-nvidia-api-key-here

# LLM Settings
LLM_TEMPERATURE=0.7

# Conversation Settings
MAX_MESSAGES=50
MIN_MESSAGES_FOR_INTELLIGENCE=2

# Scam Detection Thresholds
SCAM_CONFIDENCE_THRESHOLD=0.15
INTELLIGENCE_SUFFICIENCY_THRESHOLD=10

# Logging
LOG_LEVEL=INFO
